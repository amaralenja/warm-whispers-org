{
  "manifest_version": 3,
  "name": "Multium Meet",
  "version": "0.1.0",
  "description": "Grava mic + audio da aba (Meet/Zoom Web) e transcreve com IA.",
  "permissions": ["activeTab", "tabCapture", "storage", "offscreen", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon.png"
  }
}
